# Copy this file to .env and fill in your values
# The .env file is NEVER committed to git

# ── Security ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_random_64_char_string

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL after deployment, e.g.:
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# ── MinIO (file uploads) ─────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eduwise
# Set to your droplet's public IP:
# MINIO_PUBLIC_URL=http://YOUR_DROPLET_IP:9000
MINIO_PUBLIC_URL=http://localhost:9000

# ── AI (optional) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (optional — password reset) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
